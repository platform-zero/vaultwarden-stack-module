<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vaultwarden - Redirecting to SSO...</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            background: #111827;
            color: #f9fafb;
        }
        .container {
            text-align: center;
            padding: 2rem;
            background: #1f2937;
            border: 1px solid #374151;
            border-radius: 8px;
            backdrop-filter: blur(10px);
            box-shadow: 0 18px 60px rgba(0, 0, 0, 0.28);
        }
        h1 {
            margin: 0 0 1rem 0;
            font-size: 2rem;
            font-weight: 600;
        }
        p {
            margin: 0.5rem 0;
            font-size: 1.1rem;
            opacity: 0.9;
        }
        .spinner {
            margin: 2rem auto;
            width: 50px;
            height: 50px;
            border: 4px solid #374151;
            border-top-color: #9ca3af;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        .manual-link {
            margin-top: 2rem;
            padding-top: 2rem;
            border-top: 1px solid #374151;
        }
        a {
            color: #d1d5db;
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🔐 Vaultwarden</h1>
        <p>Redirecting to Single Sign-On...</p>
        <div class="spinner"></div>
        <div class="manual-link">
            <p>Not redirected automatically?</p>
            <p><a href="https://vaultwarden.{{DOMAIN}}/#/sso?identifier={{VAULTWARDEN_ORG_ID}}" id="manual-link">Click here to login with SSO</a></p>
        </div>
    </div>

    <script>
        // Automatic redirect to Vaultwarden SSO page with pre-filled identifier
        (function() {
            const ssoUrl = 'https://vaultwarden.{{DOMAIN}}/#/sso?identifier={{VAULTWARDEN_ORG_ID}}';

            // Redirect after a brief delay to show the loading state
            setTimeout(function() {
                window.location.href = ssoUrl;
            }, 1500);
        })();
    </script>
</body>
</html>
